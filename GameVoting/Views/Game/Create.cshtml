@model CreateGameViewModel

@{
    ViewData["Title"] = "Adicionar jogo";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h4 class="mb-4">Adicionar Jogo</h4>

                <form method="post">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Título <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="Ex: Elden Ring" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Lista <span class="text-danger">*</span></label>
                        <select asp-for="ListType" class="form-select" asp-items="Html.GetEnumSelectList<ListType>()">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="ListType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Gênero <span class="text-muted">(opcional)</span></label>
                        <input asp-for="Genre" class="form-control" placeholder="Ex: RPG, Metroidvania..." />
                        <span asp-validation-for="Genre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ano de lançamento <span class="text-muted">(opcional)</span></label>
                        <input asp-for="ReleaseYear" class="form-control" type="number" placeholder="Ex: 2024" />
                        <span asp-validation-for="ReleaseYear" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Página na loja <span class="text-muted">(opcional)</span>
                        </label>
                        <input asp-for="StorePageUrl" class="form-control"
                               placeholder="https://store.steampowered.com/app/..." />
                        <span asp-validation-for="StorePageUrl" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Salvar</button>
                        <a asp-controller="Game" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>

                    <p class="text-muted small mt-2 mb-0"><span class="text-danger">*</span> Campo obrigatório</p>
                </form>
            </div>
        </div>
    </div>
</div>
